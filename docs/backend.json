
{
  "entities": {
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "format_origin": { "type": "string", "description": "Valor original del Excel" },
        "format_normalized": { "type": "string", "enum": ["BAE", "BA", "MB", "SC", "WSC", "WE", "OTRO"] },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "impactoNeto": { "type": "number" },
        "disciplina_normalizada": { "type": "string" },
        "classification_status": { "type": "string" }
      }
    },
    "FormatAggregate": {
      "title": "Format Aggregate",
      "type": "object",
      "properties": {
        "totalImpact": { "type": "number" },
        "totalOrders": { "type": "number" },
        "lastUpdate": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/orders/{orderId}": { "schema": "Order", "description": "Registros de órdenes normalizados" },
    "/aggregates/format_analytics/formats/{formatId}": { "schema": "FormatAggregate", "description": "Totales por formato" },
    "/aggregates/format_analytics/formats/{formatId}/disciplines/{discId}": { "schema": "object", "description": "Desglose de impacto por disciplina y formato" }
  }
}
