
{
  "entities": {
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "importBatchId": { "type": "string" },
        "envelopeId": { "type": "string", "description": "DocuSign Envelope ID" },
        "orderNumber": { "type": "string", "description": "#" },
        "projectId": { "type": "string", "description": "PID/ID TRIRIGA" },
        "projectName": { "type": "string" },
        "type": { "type": "string" },
        "format": { "type": "string" },
        "country": { "type": "string", "description": "País" },
        "state": { "type": "string", "description": "Estado" },
        "municipality": { "type": "string", "description": "Municipio" },
        "coordinador": { "type": "string" },
        "plan": { "type": "string" },
        "projectStage": { "type": "string", "description": "Etapa del Proyecto" },
        "causaRaiz": { "type": "string" },
        "descripcion": { "type": "string" },
        "montoDeductiva": { "type": "number" },
        "montoAditiva": { "type": "number" },
        "impactoNeto": { "type": "number" },
        "areaSolicitante": { "type": "string" },
        "generadorDesviacion": { "type": "string", "description": "Generador de la desviación" },
        "areaEjerceRecursoDeductiva": { "type": "string" },
        "areaEjerceRecursoAditiva": { "type": "string" },
        "estatus": { "type": "string" },
        "fechaSolicitud": { "type": "string", "format": "date-time" },
        "fechaAprobacionGerente": { "type": "string", "format": "date-time" },
        "fechaPptoProyectista": { "type": "string", "format": "date-time", "description": "Fecha ppto Proyectista, Construcciones, Compras, y/o LP" },
        "noRechazo": { "type": "string" },
        "motivoRechazo": { "type": "string" },
        "fechaRetraso": { "type": "string", "format": "date-time" },
        "fechaAprobacionLider": { "type": "string", "format": "date-time", "description": "Fecha de Aprobacion Líder de Squad" },
        "importeProy": { "type": "number" },
        "importeObra": { "type": "number" },
        "importeCompras": { "type": "number" },
        "proveedor": { "type": "string" },
        "isSigned": { "type": "boolean" },
        "disciplina_normalizada": { "type": "string" },
        "causa_raiz_normalizada": { "type": "string" },
        "subcausa_normalizada": { "type": "string" },
        "confidence_score": { "type": "number" },
        "structural_quality_score": { "type": "number" },
        "reliability_level": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
        "classification_status": { "type": "string", "enum": ["pending", "auto", "reviewed", "overridden"] },
        "semanticAnalysis": { "type": "object" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "impactoNeto"]
    },
    "WordCloudSnapshot": {
      "title": "Word Cloud Snapshot",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "filters": { "type": "object" },
        "concepts": { "type": "array" },
        "executiveDiagnosis": { "type": "string" },
        "coreProblem": { "type": "string" },
        "concentrationPercentage": { "type": "number" }
      }
    },
    "DeletionJob": {
      "title": "Deletion Job",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "running", "done", "failed"] },
        "mode": { "type": "string", "enum": ["single", "bulk", "all"] },
        "progress": { "type": "number" },
        "total": { "type": "number" },
        "deletedCount": { "type": "number" },
        "userId": { "type": "string" },
        "startedAt": { "type": "string" },
        "completedAt": { "type": "string" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/orders/{orderId}": { "schema": "Order", "description": "Registros de OC/OT con trazabilidad de 32 campos" },
    "/deletion_jobs/{jobId}": { "schema": "DeletionJob", "description": "Tracking de procesos de borrado masivo" },
    "/audit_logs/{logId}": { "schema": "AuditLog", "description": "Logs de auditoría institucional" },
    "/audits/{auditId}": { "schema": "AuditLog", "description": "Historial de escaneos forenses" },
    "/word_cloud_snapshots/{snapshotId}": { "schema": "WordCloudSnapshot", "description": "Snapshots de análisis semántico 80/20" }
  }
}
