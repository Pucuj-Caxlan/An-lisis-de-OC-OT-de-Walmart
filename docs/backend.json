
{
  "entities": {
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "importBatchId": { "type": "string" },
        "envelopeId": { "type": "string", "description": "DocuSign Envelope ID" },
        "orderNumber": { "type": "string" },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "type": { "type": "string" },
        "format": { "type": "string" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "municipality": { "type": "string" },
        "coordinador": { "type": "string" },
        "plan": { "type": "string" },
        "causaRaiz": { "type": "string" },
        "descripcion": { "type": "string" },
        "montoDeductiva": { "type": "number" },
        "montoAditiva": { "type": "number" },
        "impactoNeto": { "type": "number" },
        "importeProy": { "type": "number" },
        "importeObra": { "type": "number" },
        "importeCompras": { "type": "number" },
        "areaSolicitante": { "type": "string" },
        "generadorDesviacion": { "type": "string" },
        "areaEjerceRecursoDeductiva": { "type": "string" },
        "areaEjerceRecursoAditiva": { "type": "string" },
        "estatus": { "type": "string" },
        "fechaSolicitud": { "type": "string", "format": "date-time" },
        "fechaAprobacionGerente": { "type": "string", "format": "date-time" },
        "fechaAprobacionLider": { "type": "string", "format": "date-time" },
        "fechaPptoProyectista": { "type": "string", "format": "date-time" },
        "fechaRetraso": { "type": "string", "format": "date-time" },
        "noRechazo": { "type": "string" },
        "motivoRechazo": { "type": "string" },
        "proveedor": { "type": "string" },
        "projectStage": { "type": "string" },
        "isSigned": { "type": "boolean" },
        "redFlags": { "type": "array", "items": { "type": "string" } },
        "historicalLog": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "orderNumber": { "type": "string" },
              "amount": { "type": "number" },
              "rootCause": { "type": "string" },
              "date": { "type": "string" }
            }
          }
        },
        "disciplina_normalizada": { "type": "string" },
        "causa_raiz_normalizada": { "type": "string" },
        "subcausa_normalizada": { "type": "string" },
        "confidence_score": { "type": "number" },
        "structural_quality_score": { "type": "number" },
        "reliability_level": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
        "pdf_traceability_reconstructed": { "type": "boolean" },
        "rationale_tecnico": { "type": "string" },
        "classified_at": { "type": "string", "format": "date-time" },
        "classification_status": { "type": "string", "enum": ["pending", "auto", "reviewed", "overridden"] },
        "dataSource": { "type": "string" },
        "ingestionCompleteness": { "type": "number" },
        "semanticAnalysis": { "type": "object" }
      },
      "required": ["projectId", "impactoNeto"]
    },
    "WordCloudSnapshot": {
      "title": "Word Cloud Snapshot",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "filters": { "type": "object" },
        "concepts": { "type": "array" },
        "executiveDiagnosis": { "type": "string" },
        "coreProblem": { "type": "string" },
        "concentrationPercentage": { "type": "number" }
      }
    },
    "DeletionJob": {
      "title": "Deletion Job",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "running", "done", "failed"] },
        "mode": { "type": "string", "enum": ["single", "bulk", "all"] },
        "progress": { "type": "number" },
        "total": { "type": "number" },
        "deletedCount": { "type": "number" },
        "userId": { "type": "string" },
        "startedAt": { "type": "string" },
        "completedAt": { "type": "string" }
      }
    },
    "AuditLog": {
      "title": "Audit Log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/orders/{orderId}": { "schema": "Order", "description": "Enriched records with DocuSign and historical context" },
    "/deletion_jobs/{jobId}": { "schema": "DeletionJob", "description": "Tracking for batch deletion processes" },
    "/audit_logs/{logId}": { "schema": "AuditLog", "description": "Audit trails for critical actions" },
    "/audits/{auditId}": { "schema": "AuditLog", "description": "Scan history" },
    "/word_cloud_snapshots/{snapshotId}": { "schema": "WordCloudSnapshot", "description": "Persisted 80/20 analysis results" }
  }
}
