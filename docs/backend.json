
{
  "entities": {
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "importBatchId": { "type": "string" },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "type": { "type": "string", "enum": ["OT", "OCR", "OCI"] },
        "format": { "type": "string" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "municipality": { "type": "string" },
        "plan": { "type": "string" },
        "etapaProyecto": { "type": "string" },
        "coordinador": { "type": "string" },
        "causaRaiz": { "type": "string" },
        "descripcion": { "type": "string" },
        "conceptoNormalizado": { "type": "string" },
        "montoDeductiva": { "type": "number" },
        "montoAditiva": { "type": "number" },
        "impactoNeto": { "type": "number" },
        "areaSolicitante": { "type": "string" },
        "generadorDesviacion": { "type": "string" },
        "areaEjerceRecurso": { "type": "string" },
        "estatus": { "type": "string" },
        "fechaSolicitud": { "type": "string", "format": "date-time" },
        "fechaAprobacionGerente": { "type": "string", "format": "date-time" },
        "fechaPptoProyectista": { "type": "string", "format": "date-time" },
        "proveedor": { "type": "string" },
        "qcFlags": { "type": "array", "items": { "type": "string" } },
        "rowNumber": { "type": "number" },
        "sheetName": { "type": "string" }
      }
    },
    "ImportBatch": {
      "title": "ImportBatch",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "importDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PROCESSING", "COMPLETED", "FAILED"] },
        "stats": {
          "type": "object",
          "properties": {
            "totalRows": { "type": "number" },
            "processedRows": { "type": "number" },
            "errorCount": { "type": "number" },
            "totalImpact": { "type": "number" }
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "row": { "type": "number" },
              "sheet": { "type": "string" },
              "field": { "type": "string" },
              "error": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      { "path": "/orders/{orderId}", "definition": { "entityName": "Order", "schema": { "$ref": "#/backend/entities/Order" } } },
      { "path": "/importBatches/{importBatchId}", "definition": { "entityName": "ImportBatch", "schema": { "$ref": "#/backend/entities/ImportBatch" } } }
    ]
  }
}
