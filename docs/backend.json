
{
  "entities": {
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "importBatchId": { "type": "string" },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "type": { "type": "string", "enum": ["OT", "OCR", "OCI"] },
        "format": { "type": "string" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "municipality": { "type": "string" },
        "plan": { "type": "string" },
        "etapaProyecto": { "type": "string" },
        "coordinador": { "type": "string" },
        "causaRaiz": { "type": "string" },
        "descripcion": { "type": "string" },
        "conceptoNormalizado": { "type": "string" },
        "montoDeductiva": { "type": "number" },
        "montoAditiva": { "type": "number" },
        "impactoNeto": { "type": "number" },
        "areaSolicitante": { "type": "string" },
        "generadorDesviacion": { "type": "string" },
        "areaEjerceRecurso": { "type": "string" },
        "estatus": { "type": "string" },
        "fechaSolicitud": { "type": "string", "format": "date-time" },
        "proveedor": { "type": "string" },
        "qcFlags": { "type": "array", "items": { "type": "string" } },
        "createdFromPdf": { "type": "boolean" },
        "pdfUrl": { "type": "string" },
        "standardizedDescription": { "type": "string" },
        "redFlags": {
          "type": "object",
          "properties": {
            "hasRisks": { "type": "boolean" },
            "riskScore": { "type": "number" },
            "observations": { "type": "string" }
          }
        },
        "lineItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "areaEjerce": { "type": "string" },
              "areaGenera": { "type": "string" },
              "descripcion": { "type": "string" },
              "importe": { "type": "number" }
            }
          }
        }
      }
    },
    "ImportBatch": {
      "title": "ImportBatch",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "importDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PROCESSING", "COMPLETED", "FAILED"] },
        "stats": {
          "type": "object",
          "properties": {
            "totalRows": { "type": "number" },
            "processedRows": { "type": "number" },
            "errorCount": { "type": "number" },
            "totalImpact": { "type": "number" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/orders/{orderId}": { "schema": "Order", "description": "Normalized records of OC/OT from Excel or PDF" },
    "/importBatches/{importBatchId}": { "schema": "ImportBatch", "description": "Tracking for batch ingestions" }
  }
}
