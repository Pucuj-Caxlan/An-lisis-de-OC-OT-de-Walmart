
{
  "entities": {
    "Order": {
      "title": "Order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "importBatchId": { "type": "string" },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "type": { "type": "string", "enum": ["OT", "OCR", "OCI"] },
        "format": { "type": "string" },
        "country": { "type": "string" },
        "state": { "type": "string" },
        "municipality": { "type": "string" },
        "plan": { "type": "string" },
        "etapaProyecto": { "type": "string" },
        "coordinador": { "type": "string" },
        "causaRaiz": { "type": "string" },
        "descripcion": { "type": "string" },
        "montoDeductiva": { "type": "number" },
        "montoAditiva": { "type": "number" },
        "impactoNeto": { "type": "number" },
        "areaSolicitante": { "type": "string" },
        "generadorDesviacion": { "type": "string" },
        "areaEjerceRecurso": { "type": "string" },
        "estatus": { "type": "string" },
        "fechaSolicitud": { "type": "string", "format": "date-time" },
        "proveedor": { "type": "string" },
        "qcFlags": { "type": "array", "items": { "type": "string" } },
        "createdFromPdf": { "type": "boolean" },
        "pdfUrl": { "type": "string" },
        "standardizedDescription": { "type": "string" },
        "semanticAnalysis": {
          "type": "object",
          "properties": {
            "conceptoNormalizado": { "type": "string" },
            "especialidadImpactada": { "type": "string" },
            "causaRaizReal": { "type": "string" },
            "confidence": { "type": "number" },
            "summary": { "type": "array", "items": { "type": "string" } },
            "preventiveChecks": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["projectId", "impactoNeto"]
    },
    "AuditReport": {
      "title": "Audit Report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "globalHealthScore": { "type": "number" },
        "summary": { "type": "string" },
        "anomaliesCount": { "type": "number" },
        "sampleSize": { "type": "number" },
        "anomalies": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "orderId": { "type": "string" },
              "projectId": { "type": "string" },
              "type": { "type": "string" },
              "severity": { "type": "string" },
              "finding": { "type": "string" },
              "reasoning": { "type": "string" },
              "recommendation": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "timestamp", "globalHealthScore"]
    },
    "ImportBatch": {
      "title": "Import Batch",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "importDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PROCESSING", "COMPLETED", "FAILED"] },
        "stats": {
          "type": "object",
          "properties": {
            "totalRows": { "type": "number" },
            "processedRows": { "type": "number" },
            "errorCount": { "type": "number" },
            "totalImpact": { "type": "number" }
          }
        }
      }
    },
    "ChatSession": {
      "title": "Chat Session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "content": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["userId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/orders/{orderId}": { "schema": "Order", "description": "Normalized records with semantic AI enrichment" },
    "/audits/{auditId}": { "schema": "AuditReport", "description": "Historical forensic audit reports" },
    "/importBatches/{batchId}": { "schema": "ImportBatch", "description": "Tracking for bulk excel uploads" },
    "/chatSessions/{sessionId}": { "schema": "ChatSession", "description": "Persistent chat history for IA Asistente" }
  }
}
