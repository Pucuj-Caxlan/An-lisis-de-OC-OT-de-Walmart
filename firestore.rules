
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Versión 2.3.6 - Estabilización Crítica para Walmart Operational Control
    // Esta versión prioriza la visibilidad del universo de 11,150 registros
    
    // 1. Acceso a Órdenes (Colección Principal)
    match /orders/{id} {
      // Permitir lectura total a usuarios autenticados (incluyendo custom tokens sin email)
      allow read: if request.auth != null;
      // Permitir escritura controlada para procesos de IA y auditoría
      allow write: if request.auth != null;
    }
    
    // 2. Colecciones de Soporte y Taxonomía
    match /taxonomy_disciplines/{id} { allow read: if request.auth != null; }
    match /taxonomy_causes/{id} { allow read: if request.auth != null; }
    match /classification_overrides/{id} { allow read, write: if request.auth != null; }
    match /aggregates/{document=**} { allow read: if request.auth != null; }

    // 3. Procesos Operativos y Auditoría
    match /audits/{id} { allow read, write: if request.auth != null; }
    match /audit_logs/{id} { allow read, write: if request.auth != null; }
    match /deletion_jobs/{id} { allow read, write: if request.auth != null; }
    match /word_cloud_snapshots/{id} { allow read, write: if request.auth != null; }
    match /importBatches/{id} { allow read, write: if request.auth != null; }
    
    // 4. Perfiles de Usuario
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 5. Regla Global de Respaldo (Fallback)
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false; 
    }
  }
}
