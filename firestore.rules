
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /audits/{auditId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /importBatches/{batchId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /chatSessions/{sessionId} {
      // Para listar, validamos que los documentos pertenezcan al usuario autenticado
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Acceso individual por ID
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Creación validando el userId en los datos entrantes
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Actualización y borrado validando propiedad
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
