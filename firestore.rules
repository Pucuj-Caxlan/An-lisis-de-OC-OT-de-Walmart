
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Versión de reglas para forzar despliegue: 2.1.0
    // Proporciona acceso total a usuarios autenticados para permitir auditoría masiva.
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    match /audits/{auditId} {
      allow read, write: if isSignedIn();
    }
    
    match /audit_logs/{logId} {
      allow read, create: if isSignedIn();
    }

    match /deletion_jobs/{jobId} {
      allow read, write: if isSignedIn();
    }

    match /word_cloud_snapshots/{snapshotId} {
      allow read, write: if isSignedIn();
    }

    match /importBatches/{batchId} {
      allow read, write: if isSignedIn();
    }
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Regla de respaldo para cualquier otra colección operativa
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}
