
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Versión 2.3.0 - Restauración de Compatibilidad Feb-20 + Estabilización Custom Auth
    
    function isSignedIn() {
      // Validamos UID para soportar Custom Tokens sin email (Walmart Standard)
      return request.auth != null && request.auth.uid != null;
    }
    
    // Colección Principal de Órdenes
    match /orders/{orderId} {
      // Permite listado masivo y lectura individual
      allow read: if isSignedIn();
      // Permite escritura para procesos de ingesta y clasificación IA
      allow write: if isSignedIn();
    }

    // Soporte para Taxonomías e Inteligencia Semántica
    match /taxonomy_disciplines/{id} { allow read: if isSignedIn(); }
    match /taxonomy_causes/{id} { allow read: if isSignedIn(); }
    match /classification_overrides/{id} { allow read, write: if isSignedIn(); }
    
    // Soporte para Agregados y Dashboards de Alto Nivel
    match /aggregates/{document=**} {
      allow read: if isSignedIn();
    }

    // Procesos Operativos y Auditoría
    match /audits/{id} { allow read, write: if isSignedIn(); }
    match /audit_logs/{id} { allow read, write: if isSignedIn(); }
    match /deletion_jobs/{id} { allow read, write: if isSignedIn(); }
    match /word_cloud_snapshots/{id} { allow read, write: if isSignedIn(); }
    match /importBatches/{id} { allow read, write: if isSignedIn(); }
    
    // Perfiles de Usuario
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Regla de Respaldo de Seguridad - SOLO LECTURA
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
