
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    match /audits/{auditId} {
      allow read, write: if isSignedIn();
    }

    match /importBatches/{batchId} {
      allow read, write: if isSignedIn();
    }
  }
}
