
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    match /audits/{auditId} {
      allow read, write: if isSignedIn();
    }

    match /importBatches/{batchId} {
      allow read, write: if isSignedIn();
    }

    match /chatSessions/{sessionId} {
      // Permitimos lectura (get y list) si el documento pertenece al usuario
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      // Permitimos creación validando que el userId sea el del solicitante
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Permitimos actualización y borrado si el documento existente pertenece al usuario
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
