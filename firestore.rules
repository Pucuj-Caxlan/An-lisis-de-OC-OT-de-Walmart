
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function matchesPathId(idFromPath) {
      return request.resource.data.id == idFromPath;
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && matchesPathId(orderId);
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /audits/{auditId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && matchesPathId(auditId);
      allow delete: if isSignedIn();
    }

    match /importBatches/{batchId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && matchesPathId(batchId);
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
