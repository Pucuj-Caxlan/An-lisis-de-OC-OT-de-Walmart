
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    match /orders/{orderId} {
      allow read, write: if isSignedIn();
    }

    match /audits/{auditId} {
      allow read, write: if isSignedIn();
    }
    
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /deletion_jobs/{jobId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /importBatches/{batchId} {
      allow read, write: if isSignedIn();
    }
    
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow create, update, delete: if isSignedIn() && isOwner(userId);
    }

    match /taxonomy_disciplines/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /taxonomy_rootcauses/{id} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /classification_overrides/{id} {
      allow read, write: if isSignedIn();
    }

    match /aggregates/{scope}/disciplines_stats/{id} {
      allow read, write: if isSignedIn();
    }

    match /aggregates/{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
