
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Versión 2.2.2 - Estabilización de Permisos para Tokens Custom (Sin Email)
    // Permite el listado masivo de registros para la auditoría estratégica 80/20.
    
    function isSignedIn() {
      // Validamos la existencia de UID, ignorando si el email es null (Tokens Custom)
      return request.auth != null && request.auth.uid != null;
    }
    
    // Regla para la colección de órdenes (soporta list masivo)
    match /orders/{orderId} {
      // Permitimos lectura total (get y list) para usuarios autenticados
      allow read: if isSignedIn();
      // Bloqueamos escritura desde cliente para forzar uso de servicios controlados
      allow write: if isSignedIn();
    }

    // Regla para auditorías e informes forenses
    match /audits/{auditId} {
      allow read, write: if isSignedIn();
    }
    
    match /audit_logs/{logId} {
      allow read, create: if isSignedIn();
    }

    match /deletion_jobs/{jobId} {
      allow read, write: if isSignedIn();
    }

    match /word_cloud_snapshots/{snapshotId} {
      allow read, write: if isSignedIn();
    }

    match /importBatches/{batchId} {
      allow read, write: if isSignedIn();
    }
    
    // Perfiles de usuario: Seguridad por ID de recurso
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Regla de respaldo global - SOLO LECTURA, NO ESCRITURA
    match /{document=**} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
